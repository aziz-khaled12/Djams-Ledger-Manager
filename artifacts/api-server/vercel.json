{
  "version": 2,
  "framework": "express",
  
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build",
  "builds": [
    {
      "src": "dist/index.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/index.mjs"
    }
  ]
}
